#!/bin/bash
#SBATCH --job-name=satstar-cmd-regen-brick-o001
#SBATCH --account=astronomy-dept
#SBATCH --qos=astronomy-dept-b
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=64gb
#SBATCH --time=02:00:00
#SBATCH --output=/blue/adamginsburg/adamginsburg/logs/satstar-cmd-regen-brick-o001_%j.log

# Regenerate the saturated-star CMD figures (astrometry paper app:satstar) from the
# FRESH satstar-recovered 2221 catalog, as soon as the per-exposure cataloging job
# (37553031, phases m12..m7 + m8 forced-fill/dedup) finishes successfully.
# Submit with:  sbatch --dependency=afterok:37553031 regen_satstar_cmds_afterjob.sbatch
# The m8 finalize writes the proposal-scoped 2221 all-band table with mag_vega_<band>
# + the flag columns the generator/metric need; all five CMD pairs are 2221-only, so no
# 1182 combine is required.

set -euo pipefail
PY=/blue/adamginsburg/adamginsburg/miniconda3/envs/python313/bin/python
REPO=/blue/adamginsburg/adamginsburg/repos/jwst-gc-pipeline
CATDIR=/orange/adamginsburg/jwst/brick/catalogs
OUTDIR=/orange/adamginsburg/jwst/brick/astrometry_paper/figures/evidence
STEM=basic_merged_indivexp_photometry_tables_merged_resbgsub_m8_dedup

# Resolve the freshest 2221 (o001) m8 table; prefer the proposal-scoped name.
AFTER="$CATDIR/${STEM}_o001.fits"
if [ ! -f "$AFTER" ]; then
    AFTER=$(ls -t "$CATDIR"/*m8_dedup_o001*.fits 2>/dev/null | head -1 || true)
fi
if [ -z "${AFTER:-}" ] || [ ! -f "$AFTER" ]; then
    echo "[regen] FATAL: no 2221 (o001) m8 table found under $CATDIR" >&2
    echo "[regen] cataloging job may have failed before m8, or wrote a different name." >&2
    ls -la "$CATDIR"/*m8_dedup*.fits 2>/dev/null >&2 || true
    exit 1
fi
echo "[regen] using after-catalog: $AFTER"

# "before" = the pre-July-campaign production state, so the multipair/stripfix
# figures keep their production(top)/after(bottom) two-row layout. This table has
# the 2221 mag_vega columns (older flag schema is handled by the generator's
# _col fallback). Optional: absence just makes those panels single-row.
BEFORE="$CATDIR/basic_merged_indivexp_photometry_tables_merged_ok2221or1182_20251211_abfix.fits"
BEFORE_ARG=""
[ -f "$BEFORE" ] && BEFORE_ARG="--before $BEFORE" && echo "[regen] using before-catalog: $BEFORE"

# Guard: it must actually carry the 2221 bands (not a 1182-only clobber).
"$PY" - "$AFTER" <<'PYEOF'
import sys
from astropy.table import Table
t = Table.read(sys.argv[1], memmap=True)
bands = {c[len('mag_vega_'):] for c in t.colnames if c.startswith('mag_vega_')}
need = {'f182m', 'f187n', 'f212n', 'f405n', 'f410m', 'f466n'}
missing = need - bands
if missing:
    sys.exit(f"[regen] FATAL: after-catalog missing 2221 bands {sorted(missing)}; "
             f"has {sorted(bands)}")
print(f"[regen] band check OK: {sorted(bands & need)}")
PYEOF

cd "$REPO"
"$PY" scripts/analysis/regenerate_satstar_cmds.py --after "$AFTER" $BEFORE_ARG --outdir "$OUTDIR"

echo "[regen] DONE. Figures written to $OUTDIR"

# ---- push the regenerated figures to Overleaf (origin = git.overleaf.com) ----
# Non-interactive: credential.helper=store already holds the token (verified).
PAPER=/orange/adamginsburg/jwst/brick/astrometry_paper
FIGS=(
  brick_cmd_calibrated_substituted_2026-07-10.png
  brick_multipair_cmds_beforeafter_2026-07-11.png
  brick_multiband_class_cmds_2026-07-10.png
  brick_degenerate_pair_trends_2026-07-11.png
  brick_degen_pair_hists.png
)
cd "$PAPER"
export GIT_TERMINAL_PROMPT=0
for f in "${FIGS[@]}"; do
    [ -f "figures/evidence/$f" ] && git add "figures/evidence/$f"
done
if git diff --cached --quiet; then
    echo "[regen] no figure changes to push (identical bytes) -- skipping Overleaf sync"
else
    git commit -m "satstar CMDs: regenerate from fresh m8 recovered catalog (job 37553031)

Auto-regenerated by regen_satstar_cmds_afterjob.sbatch after the per-exposure
re-cataloging completed; figures now reflect the wing-selfcal satstar channel,
not the 2026-07 demo rebuild.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_01928s8F52hwReegfFu8CSZT"
    # reconcile with any Overleaf-side edits before pushing
    git pull --rebase --autostash origin main
    git push origin main && echo "[regen] pushed regenerated figures to Overleaf main"
fi
